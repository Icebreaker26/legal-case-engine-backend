# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/tutelas_db

# Seguridad — genera un valor aleatorio seguro (mínimo 16 caracteres)
# Ejemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Servidor
PORT=4000
NODE_ENV=development

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173
